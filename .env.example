# ── Aurora Panel ──
# Copy this file to .env and fill in your values

# Required: Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars-long

# Required: Generate a DIFFERENT random string with: openssl rand -hex 32
DAEMON_JWT_SECRET=change-me-to-another-random-string-at-least-32-chars

# ── URL Configuration ──
# The URL users will access the panel from
PUBLIC_APP_URL=http://localhost:3000
# The URL the daemon uses to connect to the panel (internal Docker network URL)
PANEL_URL=http://panel:3000
# Your domain (for Caddy reverse proxy)
DOMAIN=panel.example.com

# ── Ports ──
PANEL_PORT=3000
DAEMON_PORT=8443

# ── Database ──
# SQLite (default):
DATABASE_URL=file:./data/aurora.db
# PostgreSQL (when using the with-postgres profile):
# DATABASE_URL=postgres://aurora:your-password@postgres:5432/aurora
# POSTGRES_PASSWORD=your-password

# ── Daemon Configuration ──
DAEMON_ID=node-01
DAEMON_NAME=Primary Node
DAEMON_HOST=aurora-daemon
# Directories inside the daemon container (typically leave as default)
SERVERS_DIR=/servers
DATA_DIR=/data
DOCKER_NETWORK=aurora
# Auto-restart crashed servers (true/false)
AUTO_RESTART=true
# Max auto-restart attempts before giving up
MAX_CRASH_RESTARTS=3

# ── Docker ──
DOCKER_HOST=unix:///var/run/docker.sock

# ── Modrinth API ──
PUBLIC_MODRINTH_API_URL=https://api.modrinth.com
MODRINTH_API_RATE_LIMIT=300

# ── Body Size Limit ──
BODY_SIZE_LIMIT=Infinity
